<!-- views/partials/html-navbar.ejs -->
<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container">
    <a class="navbar-brand" href="/">我的網站</a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link <%= pageName === 'ab-list' ? 'active' : '' %>"
             href="/address-book">通訊錄</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= pageName === 'ab-add' ? 'active' : '' %>"
             href="/address-book/add">新增</a>
        </li>

        <!-- 用戶區塊 -->
        <% if(session.admin){ %>
        <li class="nav-item">
          <span class="nav-link disabled">
            <i class="fa-solid fa-user me-1"></i><%= session.admin.nickname %>
          </span>
        </li>
        <li class="nav-item">
          <a href="/logout" class="nav-link text-warning">
            <i class="fa-solid fa-right-from-bracket me-1"></i>登出
          </a>
        </li>
        <% } else { %>
        <li class="nav-item">
          <a class="nav-link <%= pageName === 'login' ? 'disabled' : '' %>" href="/login">
            <i class="fa-solid fa-right-to-bracket me-1"></i>登入
          </a>
        </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
