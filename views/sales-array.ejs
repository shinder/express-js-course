<!-- views/sales-array.ejs -->
<%- include('partials/html-head') %>
<%- include('partials/html-navbar') %>
<div class="container mt-4">
  <h1>業務員資料</h1>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>員工編號</th>
        <th>姓名</th>
        <th>年齡</th>
      </tr>
    </thead>
    <tbody>
      <% for(let s of sales){ %>
      <tr>
        <td><%= s.id %></td>
        <td><%= s.name %></td>
        <td><%= s.age %></td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('partials/html-scripts') %>
<%- include('partials/html-tail') %>
